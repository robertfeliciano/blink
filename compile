#!/usr/bin/bash
set -o pipefail

FILENAME=""
OPT_LEVEL="-O0"
OPT_LEVEL_SET=false
LLVM_LL="new_output.ll"
LLVM_S="new_output.s"
LLVM_O="new_output.o"

parse_args() {
    local arg
    for arg in "$@"; do
        case "$arg" in
            -O0|-O1|-O2|-O3)
                if [[ "$OPT_LEVEL_SET" == true ]]; then
                    printf "Error: only one optimization level may be specified\n" >&2
                    return 1
                fi
                OPT_LEVEL="$arg"
                OPT_LEVEL_SET=true
                ;;
            -O*)
                printf "Error: optimization level must be one of -O0, -O1, -O2, or -O3\n" >&2
                return 1
                ;;
            -*)
                printf "Error: unknown option: %s\n" "$arg" >&2
                return 1
                ;;
            *)
                if [[ -n "$FILENAME" ]]; then
                    printf "Error: multiple input files are not supported\n" >&2
                    return 1
                fi
                FILENAME="$arg"
                ;;
        esac
    done
}

sanitize_filename() {
    local fn; fn="$1"
    if [[ -z "$fn" ]]; then
        printf "Error: missing filename argument\n" >&2
        return 1
    fi
    if [[ ! "$fn" =~ ^[A-Za-z0-9._/-]+$ ]]; then
        printf "Error: invalid characters in filename\n" >&2
        return 1
    fi
    if [[ ! "$fn" =~ \.bl$ ]]; then
        printf "Error: filename must end with .bl\n" >&2
        return 1
    fi
}

run_blink() {
    local fn; fn="$1"
    local optimization_level; optimization_level="$2"
    if ! ./blink "$optimization_level" "$fn"; then
        printf "Error: blink failed\n" >&2
        return 1
    fi
    if [[ ! -s "$LLVM_LL" ]]; then
        printf "Error: %s not created or empty\n" "$LLVM_LL" >&2
        return 1
    fi
}

compile_ll_to_s() {
    if ! llc --relocation-model=pic "$LLVM_LL" -o "$LLVM_S"; then
        printf "Error: llc failed\n" >&2
        return 1
    fi
    if [[ ! -s "$LLVM_S" ]]; then
        printf "Error: %s not created or empty\n" "$LLVM_S" >&2
        return 1
    fi
}

compile_s_to_o() {
    if ! clang "$LLVM_S" -o "$LLVM_O" -lm; then
        printf "Error: clang failed\n" >&2
        return 1
    fi
    if [[ ! -s "$LLVM_O" ]]; then
        printf "Error: %s not created or empty\n" "$LLVM_O" >&2
        return 1
    fi
}

main() {
    if ! parse_args "$@"; then
        return 1
    fi

    if ! sanitize_filename "$FILENAME"; then
        return 1
    fi

    if ! run_blink "$FILENAME" "$OPT_LEVEL"; then
        return 1
    fi

    if ! compile_ll_to_s; then
        return 1
    fi

    if ! compile_s_to_o; then
        return 1
    fi

    printf "Build completed: %s\n" "$LLVM_O"
}

main "$@"
